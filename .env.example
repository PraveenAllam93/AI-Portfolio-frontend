# ─── AWS Cognito (server-only — never exposed to the browser) ───────────────
# Used by SvelteKit +server.ts routes to call Cognito server-side.
# NOTE: In your Cognito User Pool → App client, enable "ALLOW_USER_PASSWORD_AUTH"
# under Auth flows (AWS Console → User Pools → App clients → Edit).

COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_REGION=us-east-1

# ─── Backend API (server-only) ───────────────────────────────────────────────
# Proxied by /api/upload/presigned-url — never sent to the browser.

API_BASE_URL=https://your-api-gateway.execute-api.ap-south-1.amazonaws.com/dev

# ─── CloudFront (server-only) ────────────────────────────────────────────────
# Portfolio URL is built server-side as: {CLOUDFRONT_URL}/{userId}/v1/index.html

CLOUDFRONT_URL=https://XXXXXXXXXX.cloudfront.net
